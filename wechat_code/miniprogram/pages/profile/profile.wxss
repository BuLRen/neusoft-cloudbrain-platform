.profile-page{padding-left:24rpx;padding-right:24rpx}.profile-hero{position:relative;margin-top:30rpx;padding:32rpx 22rpx 18rpx;border-radius:34rpx;overflow:hidden;background:linear-gradient(135deg,#cce6ff 0%,#8cbaf6 58%,#75a7ed 100%);box-shadow:0 18rpx 40rpx rgba(55,116,206,.2)}.profile-hero::after{content:"";position:absolute;right:-50rpx;top:-100rpx;width:310rpx;height:310rpx;border-radius:50%;background:rgba(255,255,255,.16)}.profile-row{position:relative;z-index:1;display:flex;align-items:center;min-height:108rpx}.avatar{position:relative;width:96rpx;height:96rpx;flex:none;border-radius:50%;background:rgba(255,255,255,.95);box-shadow:0 8rpx 20rpx rgba(38,99,180,.15)}.avatar-head{position:absolute;left:34rpx;top:21rpx;width:29rpx;height:29rpx;border-radius:50%;background:linear-gradient(#72c9ff,#3987ee)}.avatar-body{position:absolute;left:24rpx;bottom:17rpx;width:49rpx;height:29rpx;border-radius:30rpx 30rpx 14rpx 14rpx;background:linear-gradient(#72c9ff,#3987ee)}.identity{min-width:0;flex:1;margin-left:20rpx}.name-row{display:flex;align-items:center;gap:12rpx;white-space:nowrap}.name{font-size:34rpx;font-weight:750;color:#082363}.verified{display:inline-flex;align-items:center;white-space:nowrap;padding:5rpx 12rpx;border-radius:22rpx;background:rgba(239,255,251,.9);color:#18a98f;font-size:19rpx}.phone{display:block;margin-top:12rpx;color:#294d83;font-size:25rpx}.setting{position:relative;z-index:2;flex:none;width:154rpx;padding:14rpx 8rpx;border-radius:30rpx;text-align:center;background:rgba(255,255,255,.68);color:#526d95;font-size:21rpx;white-space:nowrap}.account-stats{position:relative;z-index:2;margin-top:26rpx;padding:24rpx 4rpx;border-radius:25rpx;display:grid;grid-template-columns:repeat(4,1fr);background:rgba(255,255,255,.97);box-shadow:0 9rpx 25rpx rgba(29,84,165,.12)}.account-stats view{display:flex;flex-direction:column;align-items:center;gap:9rpx;color:#1e315b;font-size:20rpx}.account-stats .stat-value{color:#2878ff;font-size:27rpx}.title-mark{margin-bottom:30rpx;padding-left:15rpx;border-left:7rpx solid #3f8dff}.menu{row-gap:32rpx}.service-icon{width:66rpx;height:66rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center;color:#fff;font-size:25rpx;box-shadow:0 8rpx 18rpx rgba(50,113,216,.2)}.blue-icon{background:linear-gradient(145deg,#86d7ff,#397af0)}.green-icon{background:linear-gradient(145deg,#61dfc7,#1cae96)}.purple-icon{background:linear-gradient(145deg,#b99dff,#7652ee)}.small-menu{grid-template-columns:repeat(4,1fr)}.follow-card{margin-top:24rpx;padding:30rpx 38rpx;display:flex;align-items:center;background:linear-gradient(120deg,#e8f3ff,#c9ddff)}.follow-copy{flex:1;display:flex;flex-direction:column}.follow-title{font-size:29rpx;font-weight:700}.follow-desc{margin-top:9rpx;color:#667a9f;font-size:21rpx}.follow-button{width:116rpx;margin-top:17rpx;padding:10rpx 0;border-radius:22rpx;text-align:center;background:#2878ff;color:#fff;font-size:21rpx}.qr-box{width:100rpx;height:100rpx;border:8rpx solid #fff;border-radius:18rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;background:repeating-linear-gradient(45deg,#143f87 0 5rpx,#fff 5rpx 10rpx);color:#fff;font-size:18rpx;text-shadow:0 1rpx 3rpx #072b64}
