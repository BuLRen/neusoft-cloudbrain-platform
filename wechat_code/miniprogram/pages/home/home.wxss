.hospital-name{font-size:38rpx;font-weight:800;margin:14rpx 4rpx 30rpx}.search{height:88rpx;display:flex;align-items:center;padding-left:25rpx;overflow:hidden;font-size:45rpx}.placeholder{flex:1;margin-left:15rpx;color:#7d8799;font-size:27rpx}.search-btn{align-self:stretch;display:flex;align-items:center;padding:0 32rpx;background:linear-gradient(145deg,#5598ff,#2765ee);color:#fff;font-size:28rpx}.hero{height:280rpx;margin-top:24rpx;padding:45rpx 28rpx;box-sizing:border-box;display:flex;flex-direction:column;gap:18rpx;overflow:hidden;position:relative;background:linear-gradient(125deg,#bfe1ff,#82bcf4)}.hero-title{font-size:38rpx;font-weight:800;letter-spacing:3rpx;color:#1357a5}.hero-tag{font-size:29rpx;color:#14529a}.hero-desc{font-size:24rpx;color:#38699d}.buildings{position:absolute;right:15rpx;bottom:0;display:flex;align-items:flex-end;gap:8rpx}.buildings i{display:block;width:52rpx;height:135rpx;background:repeating-linear-gradient(90deg,rgba(255,255,255,.75) 0 7rpx,rgba(42,115,184,.25) 8rpx 13rpx);transform:skewY(-8deg)}.buildings i:nth-child(2){height:190rpx}.buildings i:nth-child(3){height:110rpx}.patient{margin-top:24rpx;height:116rpx;border-radius:26rpx;padding:0 22rpx;display:flex;align-items:center;gap:16rpx;color:#fff;background:linear-gradient(110deg,#276af0,#559aff);box-shadow:0 14rpx 30rpx rgba(40,102,238,.22)}.patient view{flex:1;display:flex;flex-direction:column;gap:7rpx;font-size:23rpx}.patient view text:last-child{font-size:25rpx}.cross{display:flex;align-items:center;justify-content:center;width:65rpx;height:65rpx;border-radius:18rpx;color:#2876ef;background:#fff;font-size:39rpx}.qr{font-size:44rpx}.patient>text:last-child{font-size:21rpx}.primary{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:24rpx}.primary-item{padding:22rpx 4rpx;display:flex;flex-direction:column;align-items:center;gap:12rpx;font-size:23rpx}.primary-item small{font-size:17rpx;color:#999}.primary-item .icon-box{width:68rpx;height:68rpx}.article{display:flex;justify-content:space-between}.article>view:first-child{display:flex;flex-direction:column;gap:14rpx;font-size:25rpx}.article small{font-size:21rpx;color:#8792a7}.news{display:flex;align-items:center;justify-content:center;width:150rpx;border-radius:20rpx;font-size:65rpx;color:#fff;background:linear-gradient(140deg,#b5e2ff,#6ca3fa)}

.grid .mini-icon{font-weight:700;box-shadow:0 8rpx 18rpx rgba(55,108,191,.2)}
