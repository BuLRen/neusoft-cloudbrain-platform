.banner{height:180rpx;margin-top:28rpx;padding:32rpx;display:flex;align-items:center;background:linear-gradient(120deg,#fff,#c4e0ff)}.banner>view:first-child{flex:1;display:flex;flex-direction:column;gap:20rpx}.banner b{font-size:30rpx}.banner text{font-size:23rpx;color:#63779d}.banner>view:last-child{font-size:95rpx;color:#4a8cf5}.types{margin-top:24rpx;padding:28rpx 8rpx;display:grid;grid-template-columns:repeat(4,1fr)}.types>view{display:flex;flex-direction:column;align-items:center;gap:9rpx}.types b{font-size:22rpx}.types text{font-size:18rpx;color:#9099aa}.types .icon-box{width:64rpx;height:64rpx}.tabs{display:flex;justify-content:space-between;padding:28rpx 5rpx 17rpx;color:#68758e;font-size:23rpx}.tabs b{color:#2878ff;border-bottom:5rpx solid #2878ff;padding-bottom:12rpx}.message{position:relative;margin-bottom:18rpx;padding:24rpx;display:flex;align-items:center;gap:18rpx}.message>view:nth-child(2){flex:1;display:flex;flex-direction:column;gap:9rpx}.message b{font-size:25rpx}.message text{font-size:20rpx;color:#75829a;line-height:1.5}.message small{align-self:flex-start;font-size:19rpx;color:#8490a8}.message i{position:absolute;right:24rpx;bottom:22rpx;width:13rpx;height:13rpx;border-radius:50%;background:#f44}
