.hospital-page{padding-left:20rpx;padding-right:20rpx}.brand-card{position:relative;height:292rpx;margin-top:30rpx;padding:30rpx;box-sizing:border-box;overflow:hidden;background:linear-gradient(125deg,#eaf5ff 0%,#b9d8fa 55%,#92bdf0 100%)}.brand-logo{width:92rpx;height:92rpx;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;border:5rpx solid #2c75ce;background:rgba(255,255,255,.92);color:#1760ad}.brand-logo text:first-child{font-size:23rpx;font-weight:700}.brand-logo text:last-child{font-size:13rpx}.brand-copy{position:absolute;left:150rpx;top:34rpx;display:flex;flex-direction:column}.brand-name{font-size:34rpx;font-weight:800}.brand-sub{margin-top:10rpx;color:#315e96;font-size:23rpx}.brand-tags{display:flex;gap:10rpx;margin-top:16rpx}.brand-tags text{padding:5rpx 10rpx;border-radius:10rpx;background:rgba(255,255,255,.6);color:#2878cc;font-size:18rpx}.brand-foot{position:absolute;left:30rpx;bottom:30rpx;color:#174c89;font-size:23rpx}.cloud-art{position:absolute;right:18rpx;bottom:20rpx;width:210rpx;height:145rpx}.cloud{position:absolute;right:0;bottom:0;width:180rpx;height:72rpx;border-radius:60rpx;background:rgba(255,255,255,.34)}.building{position:absolute;bottom:20rpx;width:57rpx;background:repeating-linear-gradient(90deg,rgba(255,255,255,.8) 0 8rpx,rgba(56,124,195,.2) 8rpx 13rpx)}.building.one{right:84rpx;height:112rpx}.building.two{right:22rpx;height:88rpx}.address{margin-top:20rpx;padding:25rpx;display:flex;align-items:center}.pin{font-size:44rpx;color:#2878ff}.address>view:nth-child(2){min-width:0;flex:1;margin-left:14rpx;display:flex;flex-direction:column}.address-title{font-size:24rpx;font-weight:650}.address-sub{margin-top:7rpx;color:#8490a4;font-size:19rpx}.nav-button{width:128rpx;padding:15rpx 0;border-radius:20rpx;text-align:center;background:#eaf3ff;color:#2878ff;font-size:23rpx}.services{margin-top:20rpx;padding:28rpx 6rpx;display:grid;grid-template-columns:repeat(4,1fr)}.services>view{display:flex;flex-direction:column;align-items:center}.service-box{width:72rpx;height:72rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center;color:#fff;font-size:27rpx;box-shadow:0 8rpx 20rpx rgba(50,104,190,.18)}.color-0{background:linear-gradient(#71b9ff,#3778ee)}.color-1{background:linear-gradient(#65dec8,#22b399)}.color-2{background:linear-gradient(#ffc268,#ff842c)}.color-3{background:linear-gradient(#b99cff,#7955ee)}.service-name{margin-top:12rpx;font-size:22rpx}.service-desc{margin-top:6rpx;color:#8b96a9;font-size:17rpx}.intro{color:#334363;font-size:23rpx;line-height:1.8}.stats{display:grid;grid-template-columns:repeat(3,1fr);margin-top:24rpx}.stats view{display:flex;flex-direction:column;align-items:center;gap:8rpx;border-right:1rpx solid #e5e9f1;text-align:center}.stats view:last-child{border:0}.stat-value{color:#2878ff;font-size:26rpx;font-weight:650}.stats view>text:last-child{color:#77849a;font-size:18rpx}.data-note{display:block;margin-top:18rpx;text-align:right;color:#a0a9b8;font-size:17rpx}.platforms{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.platforms>view{padding:20rpx 8rpx;border-radius:20rpx;display:flex;flex-direction:column;align-items:center;background:#f7faff;color:#8994a7;font-size:18rpx}.platform-icon{width:66rpx;height:66rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center;color:#fff;font-size:27rpx}.blue-bg{background:linear-gradient(#71b9ff,#3778ee)}.green-bg{background:linear-gradient(#65dec8,#22b399)}.orange-bg{background:linear-gradient(#ffc268,#ff842c)}.platform-title{margin:13rpx 0 7rpx;color:#142750;font-size:21rpx;font-weight:650}.contact-card{display:flex;flex-direction:column;gap:15rpx;color:#325e9c;font-size:22rpx}.contact-card .section-title{margin-bottom:5rpx}
