.summary{margin-top:30rpx;padding:26rpx;display:flex;align-items:center}.summary>view{flex:1;display:flex;flex-direction:column;gap:10rpx}.summary text{font-size:23rpx;color:#75829a}.summary button,.visit-foot button{margin:0;padding:13rpx 20rpx;line-height:1.2;border-radius:16rpx;background:#2878ff;color:#fff;font-size:22rpx}.quick{margin-top:22rpx;padding:25rpx 10rpx;display:grid;grid-template-columns:repeat(4,1fr)}.quick>view{display:flex;flex-direction:column;align-items:center;gap:12rpx;font-size:22rpx}.tabs{margin-top:24rpx;display:flex}.tabs view{flex:1;padding:28rpx 0;text-align:center;color:#6f7b92}.tabs .active{color:#2878ff;font-weight:700;border-bottom:6rpx solid #2878ff}.notice{margin:18rpx 0;padding:18rpx;border-radius:18rpx;background:#e9f3ff;color:#3175d9;font-size:22rpx}.visit{margin-bottom:20rpx;padding:23rpx}.visit-head,.visit-foot{display:flex;justify-content:space-between;align-items:center;color:#7d8aa2;font-size:20rpx}.visit-head>text{padding:5rpx 13rpx;border-radius:10rpx;color:#09a875;background:#e2f8ef}.visit-main{display:grid;grid-template-columns:76rpx 1fr 1.3fr;gap:14rpx;align-items:center;padding:24rpx 0;border-bottom:1rpx solid #edf0f5}.round{width:70rpx;height:70rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;background:linear-gradient(145deg,#71c5ff,#276dff)}.dept,.date{display:flex;flex-direction:column;gap:9rpx;font-size:20rpx;color:#6d7b94}.dept b,.date b{font-size:24rpx;color:#10204c}.date{border-left:1rpx solid #e3e8f1;padding-left:18rpx}.visit-foot{padding-top:18rpx}
