page{min-height:100%;background:#f4f8ff;color:#071c52;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}button{font:inherit}button::after{border:0}.page-shell{min-height:100vh;box-sizing:border-box;padding:calc(env(safe-area-inset-top) + 34rpx) 28rpx 150rpx;background:radial-gradient(circle at 78% 3%,rgba(132,190,255,.42),transparent 28%),linear-gradient(180deg,#dfeeff 0,#f5f9ff 350rpx,#f7f9fd 100%)}.page-title{font-size:46rpx;line-height:1.3;font-weight:800;letter-spacing:1rpx}.page-subtitle{margin-top:12rpx;color:#6e7c99;font-size:26rpx}.card{background:rgba(255,255,255,.96);border-radius:28rpx;box-shadow:0 12rpx 35rpx rgba(40,102,190,.09)}.section{margin-top:24rpx;padding:28rpx 24rpx}.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:24rpx}.section-title{font-size:32rpx;font-weight:750}.section-more{color:#75829b;font-size:24rpx}.muted{color:#7d89a2}.icon-box{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;border-radius:22rpx;color:#fff;font-size:32rpx;font-weight:700;box-shadow:inset 0 2rpx 4rpx rgba(255,255,255,.35),0 8rpx 20rpx rgba(44,113,225,.16)}.tone-blue{background:linear-gradient(145deg,#71c5ff,#276dff)}.tone-green{background:linear-gradient(145deg,#64e4cf,#16b69e)}.tone-orange{background:linear-gradient(145deg,#ffc65d,#ff7c25)}.tone-purple{background:linear-gradient(145deg,#b69cff,#7449f5)}.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28rpx 10rpx}.grid-item{display:flex;flex-direction:column;align-items:center;text-align:center}.grid-label{margin-top:13rpx;font-size:24rpx;color:#1b2b50}.mini-icon{display:flex;align-items:center;justify-content:center;width:66rpx;height:66rpx;border-radius:19rpx;background:linear-gradient(145deg,#80cfff,#3477ef);color:#fff;font-size:26rpx;box-shadow:0 7rpx 16rpx rgba(52,119,239,.2)}
