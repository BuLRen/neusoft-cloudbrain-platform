<cover-view class="bar"><cover-view wx:for="{{list}}" wx:key="path" class="item {{selected===index?'active':''}}" data-path="{{item.path}}" bindtap="go"><cover-view class="nav-icon {{item.iconClass}}"><cover-view class="shape-a"></cover-view><cover-view class="shape-b"></cover-view><cover-view class="shape-c"></cover-view><cover-view wx:if="{{item.badge}}" class="badge">{{item.badge}}</cover-view></cover-view><cover-view class="text">{{item.text}}</cover-view></cover-view></cover-view>
