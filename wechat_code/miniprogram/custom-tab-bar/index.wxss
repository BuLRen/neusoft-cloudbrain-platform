-left:3rpx solid currentColor;border-right:3rpx solid currentColor}.profile .shape-a{position:absolute;left:14rpx;top:2rpx;width:15rpx;height:15rpx;border:3rpx solid currentColor;border-radius:50%}.profile .shape-b{position:absolute;left:7rpx;bottom:1rpx;width:29rpx;height:20rpx;border:3rpx solid currentColor;border-bottom:0;border-radius:22rpx 22rpx 0 0}.badge{position:absolute;right:-12rpx;top:-8rpx;min-width:25rpx;height:25rpx;padding:0 2rpx;border:3rpx solid #fff;border-radius:18rpx;background:#ff4c55;color:#fff;font-size:16rpx;line-height:25rpx;text-align:center}
