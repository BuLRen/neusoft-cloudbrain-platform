# 熙康云医院 - 本地 → 服务器 数据库迁移配置
# 复制为 migrate-to-server.env 后填写实际值：
#   cp migrate-to-server.env.example migrate-to-server.env

# ---------- 本地（Docker PostgreSQL）----------
LOCAL_HOST=localhost
LOCAL_PORT=3307
LOCAL_USER=postgres
LOCAL_PASSWORD=postgres123
LOCAL_DB=xikang_hospital
# Docker 容器名；留空则通过 LOCAL_HOST:LOCAL_PORT 连接
LOCAL_DOCKER_CONTAINER=xikang-postgres

# ---------- 服务器（宝塔 PostgreSQL 等）----------
REMOTE_HOST=43.139.102.203
REMOTE_PORT=5432
REMOTE_USER=xikang_hospital
REMOTE_PASSWORD=eA6CNaWFewsMGCyZ
REMOTE_DB=xikang_hospital

# ---------- 可选：SCP 上传到服务器 ----------
# 填写后可用 ./migrate-to-server.sh upload 自动上传 dump 文件
REMOTE_SSH_USER=root
REMOTE_SSH_HOST=你的服务器IP
REMOTE_SSH_PATH=/www/wwwroot/xikang-db/backups

# ---------- 导出目录 ----------
DUMP_DIR=./backups
