<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.registration.mapper.DepartmentMapper">

    <resultMap id="BaseResultMap" type="com.xikang.registration.entity.Department">
        <id column="id" property="id"/>
        <result column="dept_name" property="name"/>
        <result column="dept_code" property="code"/>
        <result column="dept_type" property="type"/>
        <result column="dept_description" property="description"/>
        <result column="delmark" property="delmark"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, dept_name, dept_code, dept_type, dept_description, delmark
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM department WHERE delmark = 0
        ORDER BY id
    </select>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM department WHERE dept_type = #{type} AND delmark = 0
        ORDER BY id
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM department WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM department WHERE dept_code = #{code}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO department (dept_name, dept_code, dept_type, dept_description, delmark)
        VALUES (#{name}, #{code}, #{type}, #{description}, 0)
    </insert>

    <update id="update">
        UPDATE department
        SET dept_name = #{name}, dept_code = #{code}, dept_type = #{type}, dept_description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        UPDATE department SET delmark = 1 WHERE id = #{id}
    </delete>

</mapper>
