<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.registration.mapper.RegistLevelMapper">

    <resultMap id="BaseResultMap" type="com.xikang.registration.entity.RegistLevel">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="price" property="price"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, price, description, status, create_time, update_time
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM regist_level WHERE status = 1
        ORDER BY id
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM regist_level WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO regist_level (name, price, description, status)
        VALUES (#{name}, #{price}, #{description}, #{status})
    </insert>

    <update id="update">
        UPDATE regist_level
        SET name = #{name}, price = #{price}, description = #{description}, status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        UPDATE regist_level SET status = 0 WHERE id = #{id}
    </delete>

</mapper>
