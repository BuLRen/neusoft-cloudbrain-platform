<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.registration.mapper.SettleCategoryMapper">

    <resultMap id="BaseResultMap" type="com.xikang.registration.entity.SettleCategory">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, code, description, status, create_time
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM settle_category WHERE status = 1
        ORDER BY id
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM settle_category WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM settle_category WHERE code = #{code}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO settle_category (name, code, description, status)
        VALUES (#{name}, #{code}, #{description}, #{status})
    </insert>

    <update id="update">
        UPDATE settle_category
        SET name = #{name}, code = #{code}, description = #{description}, status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
