<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.registration.mapper.SchedulingMapper">

    <resultMap id="BaseResultMap" type="com.xikang.registration.entity.Scheduling">
        <id column="id" property="id"/>
        <result column="rule_name" property="ruleName"/>
        <result column="week_rule" property="weekRule"/>
        <result column="delmark" property="delmark"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, rule_name, week_rule, delmark
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE id = #{id}
    </select>

    <select id="selectByDepartmentId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE delmark = 0
        ORDER BY id
    </select>

    <select id="selectByDate" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE delmark = 0
        ORDER BY id
    </select>

    <select id="selectByDepartmentAndDate" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE delmark = 0
        ORDER BY id
    </select>

    <select id="selectAvailableByDepartmentAndDate" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE delmark = 0
        ORDER BY id
    </select>

    <select id="selectByPhysicianAndDateRange" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM scheduling WHERE delmark = 0
        ORDER BY id
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO scheduling (rule_name, week_rule, delmark)
        VALUES (#{ruleName}, #{weekRule}, 0)
    </insert>

    <update id="update">
        UPDATE scheduling
        SET rule_name = #{ruleName}, week_rule = #{weekRule}
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE scheduling SET delmark = #{delmark} WHERE id = #{id}
    </update>

    <update id="updateUsedQuota">
        -- 排班表不存储号源，此方法仅作兼容
        UPDATE scheduling SET delmark = delmark WHERE id = #{id}
    </update>

    <delete id="deleteById">
        UPDATE scheduling SET delmark = 1 WHERE id = #{id}
    </delete>

</mapper>