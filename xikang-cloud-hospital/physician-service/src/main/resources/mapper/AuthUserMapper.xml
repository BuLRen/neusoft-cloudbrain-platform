<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.physician.mapper.AuthUserMapper">

    <select id="selectById" resultType="com.xikang.physician.entity.AuthUser">
        SELECT id, user_type AS userType, employee_id AS employeeId, status
        FROM users
        WHERE id = #{id}
    </select>

</mapper>
