<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xikang.medtech.mapper.CriticalValueRuleMapper">

    <resultMap id="CriticalValueRuleMap" type="com.xikang.medtech.entity.CriticalValueRule">
        <id column="id" property="id"/>
        <result column="tech_code" property="techCode"/>
        <result column="field_key" property="fieldKey"/>
        <result column="item_name" property="itemName"/>
        <result column="unit" property="unit"/>
        <result column="critical_low" property="criticalLow"/>
        <result column="critical_high" property="criticalHigh"/>
        <result column="severity" property="severity"/>
        <result column="enabled" property="enabled"/>
        <result column="creation_time" property="creationTime"/>
    </resultMap>

    <select id="selectAllEnabled" resultMap="CriticalValueRuleMap">
        SELECT * FROM critical_value_rule WHERE enabled = TRUE ORDER BY id ASC
    </select>
</mapper>
